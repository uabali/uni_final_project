#####################################
# LLM & PROVIDERS
#####################################

# Local vLLM server (required for current setup)
VLLM_SERVER_URL=http://localhost:6365/v1
VLLM_MODEL=Qwen/Qwen3-8B-AWQ

# LLM Sampling Parameters
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=512
LLM_TOP_P=0.95
LLM_FREQUENCY_PENALTY=0.0
LLM_PRESENCE_PENALTY=0.85
LLM_ENABLE_THINKING=false

# If you later use OpenAI or LiteLLM routing:
OPENAI_API_KEY=
HUGGINGFACEHUB_API_TOKEN=
OPENROUTER_API_KEY=

#####################################
# VECTOR DB / STORAGE
#####################################

QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=rag_collection
QDRANT_STARTUP_TIMEOUT=20
QDRANT_RETRY_INTERVAL=1


#####################################
# MEMORY LAYER
#####################################

# Enable multi-layer memory (Redis + Qdrant episodic)
MEMORY_ENABLED=true
REDIS_URL=redis://localhost:6379/0
MEMORY_SHORT_TERM_TTL=7200
MEMORY_SHORT_TERM_MAX_TURNS=20
MEMORY_EPISODIC_COLLECTION=memory_collection


#####################################
# RERANKER / RETRIEVAL TUNING
#####################################

RERANKER_MODEL=default          # default | fast | <hf-model>
RERANK_FAST_MODE=false
RERANK_CACHE_TTL=600
RERANK_CACHE_SIZE=100

RAG_RETRIEVAL_STRATEGY=hybrid   # hybrid | similarity | mmr | threshold | auto
RAG_BASE_K=8
RAG_BM25_WEIGHT=0.4
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=200
LOCAL_SEARCH_CONF_THRESHOLD=0.35
LOCAL_SEARCH_RERANK_THRESHOLD=0.15


#####################################
# TOOLS
#####################################

# Web search (Tavily) – fill this when you want live web search
TAVILY_API_KEY=

TOOL_CACHE_TTL=300
TOOL_CACHE_SIZE=128
WEB_SEARCH_MAX_RESULTS=3
WEB_SEARCH_SNIPPET_MAX_CHARS=160
WEB_SEARCH_COMPACT_MODE=true
WEB_SEARCH_DEPTH=basic


#####################################
# AGENT / BEHAVIOR
#####################################

AGENT_ENABLE_LOCAL_WEB_FALLBACK=true
AGENT_FAST_WEB_FINALIZE=true


#####################################
# LANGSMITH / TRACING
#####################################

LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=local-ai-stack


#####################################
# MISC
#####################################

RERANK_VERBOSE=false
RERANKER_DEVICE=cuda


#####################################
# POSTGRES (Summary Store)
#####################################

POSTGRES_URL=postgresql://rag:rag@localhost:5432/rag
SUMMARY_TRIGGER_TURNS=20


#####################################
# LITELLM (Multi-Provider Router)
#####################################

LITELLM_BASE_URL=http://localhost:4000/v1
LITELLM_API_KEY=
LITELLM_MODEL=gpt-4o-mini


#####################################
# MCP (Tool Server)
#####################################

MCP_SERVER_URL=
MCP_TIMEOUT=30
MCP_ALLOWED_TOOLS=
MCP_ONLY_TOOLS=


#####################################
# API GATEWAY (FastAPI)
#####################################

API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_KEY=
RATE_LIMIT_CHAT=30/minute
RATE_LIMIT_INGEST=10/minute
